{
    "type": "package",
    "name": "miniBill/elm-build",
    "summary": "An Elm-based build system",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "Build",
        "Path.Posix",
        "BuildTask.CommandOptions"
