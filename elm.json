        "dillonkearns/elm-pages": "12.3.0 <= v < 13.0.0",
        "elm/bytes": "1.0.8 <= v < 2.0.0",
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.1.4 <= v < 2.0.0",
        "elm/time": "1.0.0 <= v < 2.0.0",
        "elm-cardano/sha2": "1.0.0 <= v < 2.0.0",
        "elm-cardano/x-bytes": "1.1.0 <= v < 2.0.0",
        "elmcraft/core-extra": "2.3.0 <= v < 3.0.0",
        "ianmackenzie/elm-units": "2.10.0 <= v < 3.0.0",
        "miniBill/elm-fast-dict": "1.2.6 <= v < 2.0.0",
        "miniBill/elm-rope": "1.1.1 <= v < 2.0.0",
        "robinheghan/fnv1a": "1.0.0 <= v < 2.0.0",
